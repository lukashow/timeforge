{
  "name": "backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "typegen": "pocketbase-typegen --db ./pocketbase/pb_data/data.db --out src/types/pocketbase.d.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "pocketbase-typegen": "^1.3.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/pdfkit": "^0.17.4",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "minizinc": "^4.4.4",
    "nodemon": "^3.1.11",
    "pdfkit": "^0.17.2",
    "pdfkit-table": "^0.1.99",
    "pocketbase": "^0.26.6",
    "xlsx": "^0.18.5"
  }
}
